{
    local_certs
}

www.YOUR_DOMAIN.com:443 {
    tls internal

    @c2 path /api/v1/* /cdn-cgi/* /common/oauth2/* /app/*

    handle @c2 {
        reverse_proxy 172.17.0.1:8080 {
            header_up X-Real-IP {remote_host}
            transport http {
                read_timeout 120s
            }
        }
    }

    handle {
        header -Server
        header -X-Powered-By
        respond "<html><body><h1>Digital Shield HQ</h1><p>All systems operational.</p></body></html>" 200
    }
}

# HTTP → HTTPS redirect
http://www.YOUR_DOMAIN.com {
    redir https://{host}{uri} permanent
}

YOUR_DOMAIN.com {
    tls internal
    redir https://www.YOUR_DOMAIN.com{uri} permanent
}
